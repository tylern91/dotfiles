# Ghostty terminal configuration
# Docs: https://ghostty.org/docs/config

# Cursor
cursor-style = block
cursor-style-blink = false

# Font
adjust-cell-height = 30%
font-family = JetBrains Mono
font-size = 20
font-thicken = true

# Keybindings — macOS native feel
keybind = super+alt+down=goto_split:bottom
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+shift+enter=new_split:right
keybind = super+shift+minus=new_split:down
keybind = super+t=new_tab
keybind = super+w=close_surface

# Mouse
copy-on-select = clipboard
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# Scrollback
scrollback-limit = 100000

# Shell integration (works with zsh out of the box)
shell-integration = zsh

# Theme
theme = GitHub-Dark-Default

# Window
background-blur = 90
background-opacity = 0.8
confirm-close-surface = false
macos-option-as-alt = true
macos-titlebar-style = tabs
window-colorspace = "Display P3"
window-decoration = true
window-padding-balance = true
window-padding-x = 10
window-padding-y = 10
window-save-state = always
